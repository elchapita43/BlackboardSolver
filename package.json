{
  "name": "blackboardsolver",
  "version": "1.0.0",
  "description": "MVP local para sincronizar tareas pendientes de Blackboard Palermo.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test:e2e": "playwright test --timeout=300000",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug"
  },
  "keywords": [
    "blackboard",
    "playwright",
    "sqlite",
    "openrouter",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "os": [
    "win32"
  ],
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "express": "^5.2.1",
    "playwright": "^1.58.2"
  }
}
